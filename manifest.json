{
  "manifest_version": 3,
  "name": "PureMDread",
  "version": "1.0.0",
  "description": "在浏览器中美观地阅读本地Markdown文件",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": [
        "file://*/*.md",
        "file://*/*.markdown",
        "file://*/*.mdown",
        "file://*/*.mkd"
      ],
      "js": [
        "js/marked.min.js",
        "js/highlight.min.js",
        "js/content.js"
      ],
      "css": [
        "css/github-markdown.css",
        "css/highlight-github.css",
        "css/style.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "css/github-markdown.css",
        "css/highlight-github.css",
        "css/style.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
